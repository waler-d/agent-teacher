# Cursor Cloud Agent
CURSOR_API_KEY=
CURSOR_AGENT_REPO_URL=https://github.com/waler-d/agent-teacher
CURSOR_AGENT_REPO_REF=main
CURSOR_AGENT_MODEL=composer-2.5

# 飞书自建应用（https://open.feishu.cn/app）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
# 若开启事件加密，填写 Encrypt Key；未开启可留空
FEISHU_ENCRYPT_KEY=

# Upstash Redis（Vercel Marketplace 可一键接入，用于会话 agentId 与事件去重）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
